{$DOMAIN:localhost} {
    # 运行时配置（通过环境变量注入）
    handle /config.js {
        header Content-Type "application/javascript"
        header Cache-Control "no-cache, no-store, must-revalidate"
        respond `window.__APP_CONFIG__={API_BASE_URL:"{$API_BASE_URL:/api}"};`
    }

    # API 代理：去掉 /api 前缀后转发到后端
    handle_path /api/* {
        reverse_proxy {$BACKEND_URL:localhost:8082}
    }

    # 前端静态文件
    root * /srv

    # Gzip compression
    encode gzip

    # SPA fallback
    try_files {path} /index.html

    # File server
    file_server

    # Security headers
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
    }

    # Cache static assets (excluding config.js)
    @static {
        path *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot
        not path /config.js
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Cache JS files (but not config.js)
    @js {
        path *.js
        not path /config.js
    }
    header @js Cache-Control "public, max-age=31536000, immutable"
}
